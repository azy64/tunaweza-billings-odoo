<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="facture_form" model="ir.ui.view">
        <field name="name">Factures form</field>
        <field name="model">facture</field>
        <field name="arch" type="xml">
            <form string="Facture form">
                <header>
                     <field name="bill_status" widget="statusbar"/>
                </header>
                <sheet>
                    <h1>Ma Facture</h1>
                     <group>
                        <field name="customer">
                            <list>
                                <field name="customer_name"/>
                                <field name="customer_address"/>
                            </list>
                        </field>
                        <field name="company">
                             <list>
                                <field name="company_name"/>
                                <field name="company_address"/>
                            </list>
                        </field>
                        <separator/>
                    </group>
                    <group>
                        <field name="total_amount"/>
                        <field name="date_facturation"/>
                         <field name="due_date"/>
                        <field name="items"/>
                    </group>
                    
                   
                </sheet>
            </form>
        </field>
    </record>
</odoo>