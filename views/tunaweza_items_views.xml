<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="items_action" model="ir.actions.act_window">
        <field name="name">Ajouter item</field>
        <field name="res_model">items</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--model facture-->
    <record id="facture_action" model="ir.actions.act_window">
        <field name="name">Ajouter Facture</field>
        <field name="res_model">facture</field>
        <field name="view_mode">list,form</field>
    </record>
    <!---list or tree** -->
    <record id="items_tree" model="ir.ui.view">
        <field name="name">items</field>
        <field name="model">items</field>
        <field name="arch" type="xml">
            <list string="Liste des Produits">
                <field name="id"/>
                <field name="item_label"/>
                <field name="unit_price"/>
                <field name="item_tva"/>
                <field name="quantity"/>
                <field name="price_all_taxes"/>
                <field name="item_description"/>
            </list>
        </field>
    </record>

    <record id="facture_view_tree" model="ir.ui.view">
        <field name="name">facture.tree</field>
        <field name="model">facture</field>
        <field name="arch" type="xml">
            <list string="Liste des Factures">
                <field name="id"/>
                <field name="total_amount"/>
                <field name="date_facturation"/>
                <field name="bill_status"/>
            </list>
        </field>
    </record>
</odoo>
